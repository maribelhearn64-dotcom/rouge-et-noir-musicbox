   <widget class="QSlider" name="horizontalSlider">
    <property name="geometry">
     <rect>
      <x>80</x>
      <y>450</y>
      <width>511</width>
      <height>271</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">#MainWindow
QSlider::groove:horizontal {
        border: 1px solid #c8102e;
        height: 8px;
        background: #1e1e1e;           /* 深黑轨道底色 */
        margin: 0px 4px;
        border-radius: 4px;
    }

    /* 已播放的红色进度条 */
    QSlider::sub-page:horizontal {
        background: #c8102e;           /* 醒目红色进度 */
        border-radius: 4px;
    }

    /* 未播放的剩余部分 */
    QSlider::add-page:horizontal {
        background: #2a2a2a;
        border-radius: 4px;
    }

    /* 滑块（纯白色 + 红色边框，立体感） */
    QSlider::handle:horizontal {
        background: #ffffff;           /* 纯白滑块 */
        border: 3px solid #c8102e;     /* 红色粗边框 */
        width: 18px;
        height: 18px;
        margin: -5px 0;
        border-radius: 9px;            /* 圆形滑块 */
        
        /* 立体感：顶部左侧亮，底部右侧暗 */
        border-top-color:    #f5f5f5;
        border-left-color:   #f5f5f5;
        border-bottom-color: #c8102e;
        border-right-color:  #c8102e;
    }

    /* 悬停效果 */
    QSlider::handle:horizontal:hover {
        background: #ffebee;           /* 浅粉红 */
        border: 3px solid #c8102e;
    }

    /* 按下效果 */
    QSlider::handle:horizontal:pressed {
        background: #f8d7da;
        border-top-color:    #c8102e;
        border-left-color:   #c8102e;
        border-bottom-color: #f5f5f5;
        border-right-color:  #f5f5f5;
    }</string>
    </property>
    <property name="orientation">
     <enum>Qt::Horizontal</enum>
    </property>
   </widget>
   <widget class="QSlider" name="verticalSlider">
    <property name="geometry">
     <rect>
      <x>10</x>
      <y>450</y>
      <width>22</width>
      <height>121</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">#MainWindow
/* 轨道整体背景（未播放部分） */
    QSlider::groove:vertical {
        border: 1px solid #c8102e;
        width: 8px;
        background: #1e1e1e;           /* 深黑轨道底色 */
        margin: 4px 0px;
        border-radius: 4px;
    }

    /* 已播放的红色进度条（从下往上） */
    QSlider::sub-page:vertical {
        background: #2a2a2a;           /* 醒目红色 */
        border-radius: 4px;
    }

    /* 未播放的剩余部分 */
    QSlider::add-page:vertical {
        background: #c8102e;
        border-radius: 4px;
    }

    /* 滑块（纯白色 + 红色边框，立体感） */
    QSlider::handle:vertical {
        background: #ffffff;           /* 纯白滑块 */
        border: 3px solid #c8102e;     /* 红色粗边框 */
        height: 18px;
        width: 18px;
        margin: 0 -5px;                /* 让滑块居中突出 */
        border-radius: 9px;            /* 圆形滑块 */

        /* 立体感：顶部左侧亮，底部右侧暗 */
        border-top-color:    #f5f5f5;
        border-left-color:   #f5f5f5;
        border-bottom-color: #c8102e;
        border-right-color:  #c8102e;
    }

    /* 鼠标悬停效果 */
    QSlider::handle:vertical:hover {
        background: #ffebee;           /* 浅粉红 */
        border: 3px solid #c8102e;
    }

    /* 按下效果 */
    QSlider::handle:vertical:pressed {
        background: #f8d7da;
        border-top-color:    #c8102e;
        border-left-color:   #c8102e;
        border-bottom-color: #f5f5f5;
        border-right-color:  #f5f5f5;
    }</string>
    </property>
